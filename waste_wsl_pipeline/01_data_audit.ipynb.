   "source": [
    "# Cell 1: Data Loaders\n",
    "train_transforms = transforms.Compose([\n",
    "    transforms.Resize((CFG[\"img_size\"], CFG[\"img_size\"])),\n",
    "    transforms.RandomHorizontalFlip(p=0.5),\n",
    "    transforms.RandomRotation(degrees=12, fill=(114,114,114)), \n",
    "    transforms.RandomResizedCrop(CFG[\"img_size\"], scale=(0.9, 1.0), ratio=(0.9, 1.1)),\n",
    "    transforms.ColorJitter(brightness=0.1, contrast=0.1, saturation=0.1, hue=0.003),\n",
    "    transforms.GaussianBlur(kernel_size=3, sigma=(0.1, 1.5)),\n",
    "    transforms.ToTensor(),\n",
    "    transforms.Normalize(mean=[0.485, 0.456, 0.406], std=[0.229, 0.224, 0.225]),\n",
    "    transforms.RandomErasing(p=0.25, scale=(0.02, 0.08), ratio=(0.3, 3.3), value=0)\n",
    "])\n",
    "\n",
    "eval_transforms = transforms.Compose([\n",
    "    transforms.Resize((CFG[\"img_size\"], CFG[\"img_size\"])),\n",
    "    transforms.ToTensor(),\n",
    "    transforms.Normalize(mean=[0.485, 0.456, 0.406], std=[0.229, 0.224, 0.225])\n",
    "])\n",
    "\n",
    "train_set = datasets.ImageFolder('train_val/training', transform=train_transforms)\n",
    "val_set = datasets.ImageFolder('train_val/validation', transform=eval_transforms)\n",
    "test_set = datasets.ImageFolder('test_set/images', transform=eval_transforms)\n",
    "\n",
    "train_loader = DataLoader(train_set, batch_size=CFG[\"batch_size\"], shuffle=True, num_workers=4, pin_memory=False)\n",
    "val_loader   = DataLoader(val_set, batch_size=CFG[\"batch_size\"], shuffle=False, num_workers=4, pin_memory=False)\n",
    "test_loader  = DataLoader(test_set, batch_size=CFG[\"batch_size\"], shuffle=False, num_workers=4, pin_memory=False)\n",
    "\n",
    "print(f\"Data Loaded: {len(train_set)} train, {len(val_set)} val, {len(test_set)} test images.\")\n",
    "\n",
    "BEFORE_IDX = train_set.class_to_idx.get('before', 1)\n",
    "AFTER_IDX  = train_set.class_to_idx.get('after', 0)\n",
    "print(f\"Class indices — Before (waste): {BEFORE_IDX}, After (clean): {AFTER_IDX}\")"
   ]
  },

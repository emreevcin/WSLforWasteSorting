    "# Cell 2: Dataset Audit\n",
    "def denormalize(tensor):\n",
    "    mean = np.array([0.485, 0.456, 0.406])\n",
    "    std = np.array([0.229, 0.224, 0.225])\n",
    "    img = tensor.permute(1, 2, 0).numpy()\n",
    "    img = std * img + mean\n",
    "    return np.clip(img, 0, 1)\n",
    "\n",
    "fig, axes = plt.subplots(2, 4, figsize=(12, 6))\n",
    "plt.subplots_adjust(hspace=0.4)\n",
    "\n",
    "targets_array = np.array(train_set.targets)\n",
    "after_indices = np.where(targets_array == AFTER_IDX)[0][:4]\n",
    "before_indices = np.where(targets_array == BEFORE_IDX)[0][:4]\n",
    "\n",
    "for i, idx in enumerate(after_indices):\n",
    "    img, _ = train_set[idx]\n",
    "    axes[0, i].imshow(denormalize(img))\n",
    "    axes[0, i].set_title(\"Class: After (Clean)\")\n",
    "    axes[0, i].axis('off')\n",
    "\n",
    "for i, idx in enumerate(before_indices):\n",
    "    img, _ = train_set[idx]\n",
    "    axes[1, i].imshow(denormalize(img))\n",
    "    axes[1, i].set_title(\"Class: Before (Waste)\")\n",
    "    axes[1, i].axis('off')\n",
    "\n",
    "plt.suptitle(\"Dataset Sample Audit (Un-normalized for Display)\", fontsize=14)\n",
    "plt.show()\n",
    "\n",
    "classes, counts = np.unique(train_set.targets, return_counts=True)\n",
    "plt.figure(figsize=(6, 4))\n",
    "plt.bar(['After', 'Before'], counts, color=['#4C72B0', '#C44E52'])\n",
    "plt.title(\"Class Distribution (Bias Check)\")\n",
    "plt.ylabel(\"Number of Samples\")\n",
    "for i, v in enumerate(counts):\n",
    "    plt.text(i, v + 50, str(v), ha='center')\n",
    "plt.show()\n",
    "\n",
    "print(f\"Class Mapping: {train_set.class_to_idx}\")"
   ]
  }
